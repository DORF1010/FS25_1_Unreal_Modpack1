<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="attachableFrontloader" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>Q6M 3pt hitch</name>
        <specs>
            <neededPower>120</neededPower>
            <combination filterCategory="frontLoaderTools" />
            <combination filterCategory="wheelLoaderTools" />
            <combination filterCategory="telehandlerTools" />
        </specs>
        <functions>
            <function>$l10n_function_frontloader</function>
        </functions>
        <image>$data/vehicles/quicke/q6M/store_q6M.png</image>
        <price>100</price>
        <lifetime>6000</lifetime>
        <rotation>0</rotation>
        <brand>QUICKE</brand>
        <category>frontLoaders</category>
        <shopTranslationOffset>0 0.574 0</shopTranslationOffset>
        <shopRotationOffset>12.855 0 0</shopRotationOffset>
        <vertexBufferMemoryUsage>562944</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>150272</indexBufferMemoryUsage>
        <textureMemoryUsage>458752</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_frontloader</typeDesc>
        <filename>q6M/q6M.i3d</filename>
        <size width="1.35" length="2.65" height="2.6" lengthOffset="1.53"/>
        <components>
            <component centerOfMass="0 0.2 1.7" solverIterationCount="10" mass="720"/>
        </components>
        <schemaOverlay attacherJointPosition="-0.4 0" name="FRONTLOADER"/>
        <mapHotspot type="TOOL"/>
    </base>

    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="attacherJoint" jointType="implement" hardAttach="true" allowsLowering="false">
                
            </inputAttacherJoint>
		</inputAttacherJoints>
        <support animationName="moveSupport"/>
    </attachable>

    <attacherJoints>
        <attacherJoint jointType="frontloader" node="attacherJointTools" nodeVisual="attacherJointTools_visuals" allowsJointLimitMovement="false" allowsLowering="false" rotLimitSpring="7500 7500 7500" rotLimitDamping="1 1 1" transLimitSpring="7500 7500 7500" transLimitDamping="1 1 1">
            <schema position="1 0" rotation="0" invertX="false" />
        </attacherJoint>
        <sounds>
            <attach template="attach01" linkNode="q6M_main_component1" />
        </sounds>
    </attacherJoints>

    <connectionHoses>
        <target attacherJointIndices="1" type="hydraulicIn" node="targetNode01" straighteningFactor="2">
            <objectChange node="detachedAdapter01" visibilityActive="false" visibilityInactive="true" />
        </target>
        <target attacherJointIndices="1" type="hydraulicOut" node="targetNode02" straighteningFactor="2">
            <objectChange node="detachedAdapter02" visibilityActive="false" visibilityInactive="true" />
        </target>
    </connectionHoses>

    <animations>
        <animation name="moveSupport">
            <part node="supportArm01" startTime="0.00" endTime="0.75" startRot="0 0 0"  endRot="-80 0 0" />
            <part node="supportArm02" startTime="0.25" endTime="0.75" startRot="0 0 0"  endRot="-113 0 0" />

            <sound template="hingeMedium02" startTime="0.1"  direction="1"  volumeScale="2"   pitchScale="1.2" />
            <sound template="hingeMedium03" startTime="0.74"  direction="-1" volumeScale="2"   pitchScale="1.9" />
            <sound template="hingeImp"      startTime="0.1"  direction="-1" volumeScale="0.5" pitchScale="1" />
            <sound template="vibratingImp"  startTime="0.01" direction="-1" volumeScale="0.6" pitchScale="1.7" />
            <sound template="clackVar6"     startTime="0.01" direction="-1" volumeScale="2"   pitchScale="1" />
        </animation>
    </animations>

    <cylindered>
      <movingTools>
          <movingTool node="armDummy" delayedNode="arm">
              <controls axis="AXIS_FRONTLOADER_ARM" invertAxis="true" mouseSpeedFactor="0.4" iconName="FRONTLOADER_ARM_ROTATE" />
              <attacherJoint jointIndices="1" />
              <rotation rotSpeed="20" rotAcceleration="150" rotMax="10" rotMin="-94" startRot="0" detachingRotMinLimit="-10" />
              <dependentPart node="attacherRotDummy" />
              <dependentMovingTool node="attacherDummy" minRotLimits="-40 -45" maxRotLimits="100 65"/>
          </movingTool>
          <movingTool node="attacherDummy" delayedNode="attacher">
              <controls axis="AXIS_FRONTLOADER_TOOL" invertAxis="true" mouseSpeedFactor="0.4" iconName="FRONTLOADER_ARM_ROTATE_TOOL" />
              <attacherJoint jointIndices="1" />
              <rotation rotSpeed="50" rotAcceleration="300" rotMax="180" rotMin="-55" startRot="0" syncMaxRotLimits="true" />
          </movingTool>
		  
		<movingTool node="movingParts" playSound="true">
			<controls axis="AXIS_FRONTLOADER_ARM2" invertAxis="false" mouseSpeedFactor="0.25" iconName="CRANE_ARM2_TRANSLATE"/>
			<attacherJoint jointIndices="1"/>
			<translation transSpeed="0.9" transAcceleration="10" transMax="5" transMin="0" translationAxis="2"/>
		</movingTool>

          <movingTool node="arm">
              <dependentPart node="armHydraulic" />
              <dependentPart node="attacherRot" />
              <dependentPart node="part01" />
          </movingTool>
          <movingTool node="attacher">
              <dependentPart node="wingFront" />
              <dependentPart node="hydraulicFront" />
          </movingTool>
      </movingTools>

      <movingParts>
          <movingPart node="attacherRotDummy" referenceFrame="attacherRootDummy">
              <attacherJoint jointIndices="1" />
          </movingPart>
          <movingPart node="attacherRot" referenceFrame="q6M_main_component1">
              <attacherJoint jointIndices="1" />
              <dependentPart node="wingFront" />
          </movingPart>
          <movingPart node="armHydraulic" referencePoint="armHydraulicRef" referenceFrame="armHydraulicRef">
            <translatingPart node="armHydraulicPunch" />
          </movingPart>
          <movingPart node="part01" localReferencePoint="part02" referencePoint="part02Ref" referenceFrame="part01RefFrame">
              <dependentPart node="part02" />
              <dependentPart node="hydraulicFront" />
          </movingPart>
          <movingPart node="part02" referencePoint="part02Ref" referenceFrame="part02Ref"/>
          <movingPart node="wingFront" localReferencePoint="wingPart" referencePoint="wingPartRef" referenceFrame="wingFrontRefFrame" >
              <dependentPart node="wingPart" />
          </movingPart>
          <movingPart node="wingPart" referencePoint="wingPartRef" referenceFrame="wingPartRefFrame"/>
          <movingPart node="hydraulicFront" referencePoint="hydraulicFrontRef" referenceFrame="hydraulicFrontRef" playSound="true">
              <translatingPart node="hydraulicFrontPunch" />
          </movingPart>
      </movingParts>

      <sounds>
            <actionSound template="hydraulicOpen06"  pitchScale="0.4" volumeScale="0.2" linkNode="armDummy"      actionNames="TOOL_MOVE_POS"               nodes="armDummy"      fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicOpen02"  pitchScale="0.9" volumeScale="1.7" linkNode="armDummy"      actionNames="TOOL_MOVE_POS"               nodes="armDummy"      fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicClose03" pitchScale="1.4" volumeScale="2.9" linkNode="armDummy"      actionNames="TOOL_MOVE_NEG"               nodes="armDummy"      fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicOpen06"  pitchScale="0.7" volumeScale="0.5" linkNode="armDummy"      actionNames="TOOL_MOVE_NEG"               nodes="armDummy"      fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicClose01" pitchScale="1.7" volumeScale="1"   linkNode="attacherDummy" actionNames="TOOL_MOVE_POS TOOL_MOVE_NEG" nodes="attacherDummy" fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="metalLowVar2"     pitchScale="1.0" volumeScale="3"   linkNode="armDummy"      actionNames="TOOL_MOVE_END_POS_LIMIT"     nodes="armDummy"/>
            <actionSound template="cylinderPunch"    pitchScale="1.5" volumeScale="0.4" linkNode="armDummy"      actionNames="TOOL_MOVE_END_POS_LIMIT"     nodes="armDummy"/>
            <actionSound template="metalClose"       pitchScale="2.5" volumeScale="0.2" linkNode="armDummy"      actionNames="TOOL_MOVE_END_POS_LIMIT"     nodes="armDummy"/>
            <actionSound template="clackVar6"        pitchScale="1.0" volumeScale="1.0" linkNode="armDummy"      actionNames="TOOL_MOVE_END_POS_LIMIT"     nodes="armDummy"/>
            <actionSound template="metalLowVar2"     pitchScale="1.3" volumeScale="2.0" linkNode="armDummy"      actionNames="TOOL_MOVE_END_NEG_LIMIT"     nodes="armDummy"/>
            <actionSound template="cylinderPunch"    pitchScale="1.8" volumeScale="0.2" linkNode="armDummy"      actionNames="TOOL_MOVE_END_NEG_LIMIT"     nodes="armDummy"/>
            <actionSound template="metalClose"       pitchScale="2.8" volumeScale="0.1" linkNode="armDummy"      actionNames="TOOL_MOVE_END_NEG_LIMIT"     nodes="armDummy"/>
            <actionSound template="clackVar6"        pitchScale="1.8" volumeScale="0.5" linkNode="armDummy"      actionNames="TOOL_MOVE_END_NEG_LIMIT"     nodes="armDummy"/>
        </sounds>
    </cylindered>

    <ai>
        <agentAttachment width="1.35" height="2.05" length="2.9" lengthOffset="1.25"/>
    </ai>

    <wearable wearDuration="480" workMultiplier="5" fieldMultiplier="2"/>
    <washable dirtDuration="90"  workMultiplier="3" fieldMultiplier="2" washDuration="1"/>

    <foliageBending>
        <bendingNode minX="-0.62" maxX="0.62" minZ="-0.4" maxZ="0.3" yOffset="-0.1" node="attacherRot"/>
    </foliageBending>

    <baseColorConfigurations useDefaultColors="true">
        <baseColorConfiguration materialTemplateName="QUICKE_BLACK1"/>

        <material materialSlotName="q6m_base_color_mat"/>
    </baseColorConfigurations>

    <designColorConfigurations useDefaultColors="true">
        <designColorConfiguration materialTemplateName="QUICKE_BLACK1"/>

        <material materialSlotName="q6m_design_color_mat"/>
    </designColorConfigurations>

    <i3dMappings>
        <i3dMapping id="q6M_main_component1" node="0>" />
        <i3dMapping id="q6M_vis" node="0>0" />
        <i3dMapping id="attacherJoint" node="0>0|0" />
        <i3dMapping id="arm" node="0>0|1|0" />
        <i3dMapping id="attacherRot" node="0>0|1|0|0" />
        <i3dMapping id="attacher" node="0>0|1|0|0|0" />
        <i3dMapping id="attacherJointTools_visuals" node="0>0|1|0|0|0|0" />
        <i3dMapping id="attacherJointToolsLow_visuals" node="0>0|1|0|0|0|0|0" />
        <i3dMapping id="wingPartRef" node="0>0|1|0|0|0|1" />
        <i3dMapping id="detachedAdapter01" node="0>0|1|0|0|0|3" />
        <i3dMapping id="detachedAdapter02" node="0>0|1|0|0|0|4" />
        <i3dMapping id="targetNode01" node="0>0|1|0|0|0|5" />
        <i3dMapping id="targetNode02" node="0>0|1|0|0|0|6" />
        <i3dMapping id="supportArm01" node="0>0|1|0|1" />
        <i3dMapping id="supportArm02" node="0>0|1|0|2" />
        <i3dMapping id="wingFrontRefFrame" node="0>0|1|0|3" />
        <i3dMapping id="wingFront" node="0>0|1|0|4" />
        <i3dMapping id="wingPart" node="0>0|1|0|4|0" />
        <i3dMapping id="hydraulicFrontRef" node="0>0|1|0|4|1" />
        <i3dMapping id="wingPartRefFrame" node="0>0|1|0|5" />
        <i3dMapping id="armHydraulic" node="0>0|1|0|6" />
        <i3dMapping id="armHydraulicPunch" node="0>0|1|0|6|0" />
        <i3dMapping id="part02Ref" node="0>0|1|0|7" />
        <i3dMapping id="part01RefFrame" node="0>0|1|0|8" />
        <i3dMapping id="hydraulicIn01" node="0>0|1|0|9|0" />
        <i3dMapping id="hydraulicIn02" node="0>0|1|0|9|1" />
        <i3dMapping id="hydraulicIn03" node="0>0|1|0|9|2" />
        <i3dMapping id="hydraulicIn04" node="0>0|1|0|9|3" />
        <i3dMapping id="armDummy" node="0>0|1|1" />
        <i3dMapping id="attacherRotDummy" node="0>0|1|1|0" />
        <i3dMapping id="attacherDummy" node="0>0|1|1|0|0" />
        <i3dMapping id="attacherJointTools" node="0>0|1|1|0|0|0" />
        <i3dMapping id="attacherJointToolsLow" node="0>0|1|1|0|0|0|0" />
        <i3dMapping id="attacherRootDummy" node="0>0|1|2" />
        <i3dMapping id="attacherJointDummy" node="0>0|1|2|0" />
        <i3dMapping id="part01" node="0>0|1|3" />
        <i3dMapping id="part02" node="0>0|1|3|0" />
        <i3dMapping id="hydraulicFront" node="0>0|1|3|0|0" />
        <i3dMapping id="hydraulicFrontPunch" node="0>0|1|3|0|0|0" />
        <i3dMapping id="armHydraulicRef" node="0>0|1|4" />
		<i3dMapping id="movingParts" node="0>0|1" />
        
    </i3dMappings>
</vehicle>
