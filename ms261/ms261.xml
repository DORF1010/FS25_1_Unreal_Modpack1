<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<handTool type="chainsaw" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/handTool.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>MS 261 FastCut</name>
        <functions>
            <function>$l10n_function_chainsaw</function>
        </functions>
        <image>ms261/store_ms261.dds</image>
        <price>1000</price>
        <lifetime>6000</lifetime>
        <rotation>0</rotation>
        <brand>STIHL</brand>
        <category>chainsaws</category>
        <species>HANDTOOL</species>
        <storeIconRendering>
            <settings cameraXRot="-20" cameraYRot="40"/>
        </storeIconRendering>
    </storeData>

    <base mass="4.9" canCrouch="true" runMultiplier="10">
        <typeDesc>$l10n_typeDesc_chainsaw</typeDesc>
        <filename>ms261/ms261.i3d</filename>
        <sounds filename="ms261/sounds/ms261.xml"/>
        <graphics node="graphics" lockFirstPerson="true"/>
        <handNode node="cutHandNode" useLeftHand="true" />
        <firstPersonNode node="firstPersonNode"/>
    </base>

    <storable>
        <holderType type="CHAINSAW" node="holderNode"/>
    </storable>

    <motorized>
        <exhaustEffects>
            <exhaustEffect node="exhaustParticle" filename="$data/effects/exhaust/exhaust.i3d" minLoadColor="0.9 0.9 0.9 0.1" maxLoadColor="0.9 0.9 0.9 0.4" minLoadScale="0.05" maxLoadScale="0.5" />
        </exhaustEffects>

        <motor startTime="4" minRPM="2800" maxRPM="10200" rpmVariability="0.2" rpmVariabilityChange="1"/>

        <vibrations amount="0.0002 0.0005 0.0003" node="graphics"/>
    </motorized>

    <chainsaw maximumCutDiameter="200" maximumDelimbDiameter="100" cutTimePerSquareMeter="0.01">
        <playerWorkStylePreset>chainsawSetStihl</playerWorkStylePreset>
        <chain>
            <animationNode class="ScrollingAnimation" node="chain" scrollSpeed="-20" speedFunc="getChainSpeedFactor" shaderParameterComponent="2" turnOnFadeTime="0.5" turnOffFadeTime="1"/>
        </chain>
        <effects>
            <effectNode effectClass="ParticleEffect" effectNode="chipsEmitter"       particleType="CHAINSAW_WOOD" emitCountScale="10"/>
            <effectNode effectClass="ParticleEffect" effectNode="dustEmitter"        particleType="CHAINSAW_DUST" emitCountScale="20"/>
            <effectNode effectClass="ParticleEffect" effectNode="dustVentEmitter"    particleType="CHAINSAW_DUST" emitCountScale="40" spriteScale="0.15"/>
        </effects>
        <ringSelector filename="$data/handTools/shared/treeCutters/chainsawRingSelector.i3d"/>
        <cutNode node="cutNode"/>
    </chainsaw>

	<baseColorConfigurations useDefaultColors="true">
		<material materialSlotName="ms261_STIHL_WHITE_1_mat"/>
		<baseColorConfiguration materialTemplateName="STIHL_ORANGE_1"/>
		<baseColorConfiguration materialTemplateName="STIHL_WHITE_1" isDefault="true"/>
	</baseColorConfigurations>

	<designColorConfigurations useDefaultColors="true">
		<material materialSlotName="ms261_STIHL_ORANGE_1_mat"/>
		<designColorConfiguration materialTemplateName="STIHL_ORANGE_1"/>
		<designColorConfiguration materialTemplateName="STIHL_WHITE_1"/>
	</designColorConfigurations>

    <i3dMappings>
        <i3dMapping id="graphics" node="0>0" />
        <i3dMapping id="chain" node="0>0|0" />
        <i3dMapping id="chipsEmitter" node="0>0|1|0" />
        <i3dMapping id="dustEmitter" node="0>0|1|1" />
        <i3dMapping id="dustVentEmitter" node="0>0|1|2" />
        <i3dMapping id="cutNode" node="0>0|3" />
        <i3dMapping id="firstPersonNode" node="0>1" />
        <i3dMapping id="holderNode" node="0>2" />
        <i3dMapping id="rightHandTarget" node="0>3" />
        <i3dMapping id="leftHandTarget" node="0>4" />
        <i3dMapping id="handNode" node="0>5" />
        <i3dMapping id="cutHandNode" node="0>6" />
        <i3dMapping id="walkHandNode" node="0>7" />
    </i3dMappings>
</handTool>
