<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<sounds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/vehicle_sounds.xsd">
    <motorized>
        <sounds>
            <motor template="engineSmall" file="$data/vehicles/international/cvSeries/sounds/internationalCV_loop.gls" linkNodeOffset="0.45 1.8 1.2" pitchScale="1" volumeScale="1.0" >
                <volume outdoor="1.0" indoor="0.65"/>
            </motor>
            <motor template="fanTruck_01" volumeScale="2" linkNodeOffset="0 1 2" />
            <gearbox template="transmissionModern_09" volumeScale="1" linkNodeOffset="0.6 -0.5 -2.0" />
            <gearbox template="transmissionModern_09" volumeScale="1" linkNodeOffset="-0.6 -0.5 -2.0" pitchScale="0.75" />
            <gearbox template="cabinTruck_01" linkNodeOffset="0.65 2 1.2" volumeScale="1.0" pitchScale="1.0" />
            <gearbox template="cabinTruck_01" linkNodeOffset="-0.65 2 1.2" volumeScale="1.0" pitchScale="0.90"  />
            <motor template="indoorCabinRumble" volumeScale="20" pitchScale="1.3"/>
        </sounds>
    </motorized>

    <enterable>
        <sounds>
            <rain template="rainInVehicle" linkNodeOffset="0.45 1.8 0.8">
                <loopSynthesisRpm>
                    <modifier type="SPEED" value="0.0" modifiedValue="0.0" />
                    <modifier type="SPEED" value="42.0" modifiedValue="1" />
                </loopSynthesisRpm>
                <volume>
                    <modifier type="SPEED" value="0" modifiedValue="1" />
                    <modifier type="SPEED" value="25" modifiedValue="1" />
                    <modifier type="SPEED" value="42" modifiedValue="1.2" />
                </volume>

                <pitch>
                    <modifier type="SPEED" value="0" modifiedValue="1" />
                    <modifier type="SPEED" value="25" modifiedValue="1" />
                    <modifier type="SPEED" value="42" modifiedValue="1.0" />
                </pitch>
            </rain>
            <hail template="hailInVehicle" linkNodeOffset="0.45 1.8 0.8" volumeScale="1.5">
                <loopSynthesisRpm>
                    <modifier type="SPEED" value="0.0" modifiedValue="0.0" />
                    <modifier type="SPEED" value="60.0" modifiedValue="1" />
                </loopSynthesisRpm>
                <volume>
                    <modifier type="SPEED" value="0" modifiedValue="1" />
                    <modifier type="SPEED" value="25" modifiedValue="1" />
                    <modifier type="SPEED" value="60" modifiedValue="1.2" />
                </volume>

                <pitch>
                    <modifier type="SPEED" value="0" modifiedValue="1" />
                    <modifier type="SPEED" value="25" modifiedValue="1" />
                    <modifier type="SPEED" value="60" modifiedValue="1.0" />
                </pitch>
            </hail>
        </sounds>
    </enterable>

    <lights>
        <sounds>
            <toggleLights template="switch01"  />
            <turnLight template="switchTurnlight"  />
        </sounds>
    </lights>

    <drivable>
        <sounds>
            <waterSplash template="waterSplash01" />
        </sounds>
    </drivable>

    <honk>

        <sound template="honkCar" volumeScale="3" linkNodeOffset="0.5 1 1"/>
    </honk>

</sounds>