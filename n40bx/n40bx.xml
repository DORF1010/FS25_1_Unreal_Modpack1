    </base>

     <wheels>
        <wheelConfigurations>
            <wheelConfiguration name="$l10n_configuration_valueDefault" price="0" brand="MITAS" saveId="MITAS_DEFAULT">
                <wheels>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="true" hasTireTracks="true" hasParticles="true">
                        <physics tipOcclusionAreaGroupId="1" restLoad="0.5" repr="wheelFrontLeft"  useReprDirection="true" forcePointRatio="0.15" initialCompression="15" suspTravel="0.05" spring="62" damper="15" yOffset="0.02"/>
                        <wheelChock parkingNode="wheelChock02_left" filename="$data/shared/assets/wheelChocks/wheelChock02.i3d" isInverted="true" />
                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="false" hasTireTracks="true" hasParticles="true">
                        <physics tipOcclusionAreaGroupId="1" restLoad="0.5" repr="wheelFrontRight" useReprDirection="true" forcePointRatio="0.15" initialCompression="15" suspTravel="0.05" spring="62" damper="15" yOffset="0.02"/>
                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="true" hasTireTracks="true" hasParticles="true">
                        <physics tipOcclusionAreaGroupId="1" restLoad="0.5" repr="wheelBackLeft"   useReprDirection="true" forcePointRatio="0.15" initialCompression="15" suspTravel="0.05" spring="62" damper="15" yOffset="0.02"/>
                        <wheelChock parkingNode="wheelChock02_right" filename="$data/shared/assets/wheelChocks/wheelChock02.i3d" />
                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="false" hasTireTracks="true" hasParticles="true">
                        <physics tipOcclusionAreaGroupId="1" restLoad="0.5" repr="wheelBackRight"  useReprDirection="true" forcePointRatio="0.15" initialCompression="15" suspTravel="0.05" spring="62" damper="15" yOffset="0.02"/>
                    </wheel>
                </wheels>
            </wheelConfiguration>
        </wheelConfigurations>

        <dynamicallyLoadedWheels>
            <dynamicallyLoadedWheel linkNode="wheelSpare" filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml"/>
        </dynamicallyLoadedWheels>

        <hubs>
