            <part node="supportArmBolt"  startTime="0.30" endTime="0.35" startTrans="0.013 0.129 -0.021" endTrans="0.013 0.017 -0.021" />
            <part node="supportArmCrank" startTime="0.30" endTime="1.00" startRot="0 1080 0" endRot="0 0 0" />
            <part node="supportArmPart"  startTime="0.30" endTime="1.00" startTrans="-0.042 0.05 0.000" endTrans="-0.042 0.03 0.000" />
            <part node="supportColPart"  startTime="0.90" endTime="1.00" startTrans="-0.133 0.769 4.832" endTrans="-0.133 0.45 4.832" direction="-1"/>
