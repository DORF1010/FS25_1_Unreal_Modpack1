            <sound template="hingeImp"          startTime="0.2" direction="-1" volumeScale="0.5" pitchScale="0.7"  linkNode="supportArm"/>
            <sound template="hingeImp"          startTime="0.01" direction="1" volumeScale="0.5" pitchScale="1.3"  linkNode="supportArm"/>
        </animation>
		<animation name="headerTransportExtend">
            <part node="cutterAttacherMoving"  startTime="0.00" endTime="3" startTrans="0 0 0" startRot="0 0 0" endTrans="1 0.5 7" endRot="10 0 -22"/>
			<!--<part node="cutterAttacherMoving"  startTime="3" endTime="5" startTrans="1 0.5 7" endTrans="1 7 3" startRot="10 0 -22" endRot="45 0 -22"/>?-->
        </animation>
		<animation name="headerTransportMoveUp">
            <!--<part node="cutterAttacherMoving"  startTime="0.00" endTime="3" startTrans="0 0 0" startRot="0 0 0" endTrans="1 0.5 7" endRot="10 0 -22"/>/-->
			<part node="cutterAttacherMoving"  startTime="3" endTime="6" startTrans="1 0.5 7" endTrans="0.25 3 -5" startRot="10 0 -22" endRot="20 0 -22"/>
			<part node="stablizerLeft" startTime="2" endTime="5" startTrans="0 0.5 0" endTrans="-2 0.5 -0.1" startRot="0 0 0" endRot="0 0 0"/>
			<part node="stablizerRight" startTime="2" endTime="5" startTrans="0 0.5 0" endTrans="2 0.5 -0.1" startRot="0 0 0" endRot="0 0 0"/>
        </animation>
		
    </animations>

    <cylindered>
