        <lifetime>600</lifetime>
        <rotation>0</rotation>
        <brand>NARDI</brand>
        <category>cutterTrailers</category>
        <shopTranslationOffset>0 -0.112 0</shopTranslationOffset>
        <shopRotationOffset>0.88 0 0</shopRotationOffset>
        <vertexBufferMemoryUsage>478464</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>137984</indexBufferMemoryUsage>
