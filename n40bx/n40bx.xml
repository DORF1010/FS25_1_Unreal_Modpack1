    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="attacherJoint" jointType="trailer" rootNode="n40bx_main_component1" attacherHeight="0.72"/>
        </inputAttacherJoints>
        <support animationName="moveSupport" delayedOnAttach="false" detachAfterAnimation="false"/>
        <brakeForce force="0.18"/>
    </attachable>

    <attacherJoints>
        <attacherJoint node="cutterTransportAttacher" jointType="cutter" lowerRotLimit="0 0 0" upperRotationOffset="0" allowsJointLimitMovement="true" canTurnOnImplement="false" comboTime="1" allowsLowering="true" updateAttacherJoint="true" hardAttach="true">
            <schema position="0 0.5" rotation="0" invertX="false"/>
            <attachSound template="attach01" linkNode="cutterTransportAttacher"/>
        </attacherJoint>
    </attacherJoints>

    <connectionHoses>
        <hose inputAttacherJointIndices="1" type="electric" node="electric" adapterNode="electric_detached" length="1.0" diameter="0.01" straighteningFactor="1">
            <objectChange node="electric_detached" visibilityActive="false" visibilityInactive="true" />
        </hose>
    </connectionHoses>

    <licensePlates>
        <licensePlate node="licensePlate" position="BACK" preferedType="SQUARISH" placementArea="0.08 0.2 0.2 0.2"/>
    </licensePlates>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="wheelChockSupport01_left"  filename="$data/shared/assets/wheelChocks/wheelChockSupport01.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="wheelChockSupport01_right" filename="$data/shared/assets/wheelChocks/wheelChockSupport01.i3d"/>
    </dynamicallyLoadedParts>

    <lights>
        <sharedLight linkNode="plateNumberLight02_01" filename="$data/shared/assets/lights/lizard/plateNumberLight02.xml" />

        <realLights>
            <high>
                <light node="backLightsHigh1"       lightTypes="0" />
                <light node="licensePlateLightHigh" lightTypes="0" />
                <turnLightLeft node="turnLightLeftBack" />
                <turnLightRight node="turnLightRightBack" />
                <brakeLight node="backLightsHigh1" />
            </high>
        </realLights>

        <staticLightCompounds>
            <staticLightCompound>
                <node node="n40BXLights_static" intensity="5"/>
                <node node="n40BXLightsGlass_static" intensity="1"/>
            </staticLightCompound>
        </staticLightCompounds>

        <beaconLights>
            <beaconLight node="beaconLight03" filename="$data/shared/assets/beaconLights/lizard/beaconLight03.xml" mountType="POLE" variationName="ROTATE"/>
        </beaconLights>
    </lights>

    <dynamicMountAttacher triggerNode="dynamicMountTrigger" rootNode="n40bx_main_component1" jointNode="cutterJointNode" forceAcceleration="500" mountType="TYPE_AUTO_ATTACH_XZ" transferMass="true">
        <lockPosition jointNode="caseTerraFlex3020" xmlFilename="terraFlex3020/terraFlex3020.xml"/>
        <lockPosition jointNode="claasVario620" xmlFilename="rrXL9/rrXL9.xml">
            <objectChange node="mountingPart01" translationActive="0 0 -1.366"/>
            <objectChange node="mountingPart02" translationActive="0 0 0.721"/>
        </lockPosition>
        <!--<lockPosition jointNode="caseHeader4408" xmlFilename="cr11/fd250.xml">
            <objectChange node="mountingPart01" translationActive="0 0 -0.8"/>
            <objectChange node="colPart02" translationActive="0 -0.1 0"/>
            <objectChange node="colPart03" translationActive="0 -0.1 0"/>
        </lockPosition>/-->
    </dynamicMountAttacher>

    <animations>
        <animation name="moveSupport">
            <part node="supportArmBolt"  startTime="0.00" endTime="0.05" startTrans="0.013 0.017 -0.021" endTrans="0.013 0.129 -0.021" />
