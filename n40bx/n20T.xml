        </movingParts>

        <sounds>
            <actionSound template="hydraulicOpen02" volumeScale="1.7" pitchScale="1.8" linkNode="extensionBack" actionNames="TOOL_MOVE_POS TOOL_MOVE_NEG" nodes="extensionBack" fadeIn="0.1" fadeOut="0.1"/>
            <actionSound template="metalScrape"     volumeScale="0.5" pitchScale="0.5" linkNode="extensionBack" actionNames="TOOL_MOVE_POS TOOL_MOVE_NEG" nodes="extensionBack" fadeIn="0.1" fadeOut="0.1"/>
            <actionSound template="clackVar6"       volumeScale="2.0" pitchScale="0.7" linkNode="extensionBack" actionNames="TOOL_MOVE_END_POS_LIMIT TOOL_MOVE_END_NEG_LIMIT" nodes="extensionBack" fadeIn="0.1" fadeOut="0.1"/>
            <actionSound template="vibratingImp"    volumeScale="1.2" pitchScale="1.1" linkNode="extensionBack" actionNames="TOOL_MOVE_END_POS_LIMIT TOOL_MOVE_END_NEG_LIMIT" nodes="extensionBack" fadeIn="0.1" fadeOut="0.1"/>
        </sounds>
