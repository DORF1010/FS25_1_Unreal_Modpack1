                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="false" hasTireTracks="true" hasParticles="true">
                        <physics restLoad="0.4" repr="wheelFrontRight" forcePointRatio="0.15" initialCompression="10" suspTravel="0.05" spring="62" damper="15" yOffset="0.009" frictionScale="2"/>
                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="true" hasTireTracks="true" hasParticles="true">
                        <physics restLoad="0.4" repr="wheelBackLeft"   forcePointRatio="0.15" initialCompression="10" suspTravel="0.05" spring="62" damper="15" yOffset="0.01" frictionScale="2"/>
                    </wheel>
                    <wheel filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml" isLeft="false" hasTireTracks="true" hasParticles="true">
                        <physics restLoad="0.4" repr="wheelBackRight"  forcePointRatio="0.15" initialCompression="10" suspTravel="0.05" spring="62" damper="15" yOffset="0.01" frictionScale="2"/>
                    </wheel>
                </wheels>
            </wheelConfiguration>
        </wheelConfigurations>

        <dynamicallyLoadedWheels>
            <dynamicallyLoadedWheel linkNode="wheelSpare" filename="$data/shared/wheels/tires/mitas/FL02/6_50_R10.xml"/>
        </dynamicallyLoadedWheels>

        <hubs>
