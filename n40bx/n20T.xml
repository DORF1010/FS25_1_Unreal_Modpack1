            <movingTool node="extensionBack" playSound="true">
                <controls axis="AXIS_FRONTLOADER_ARM" invertAxis="false" mouseSpeedFactor="0.3" iconName="CRANE_ARM2_ROTATE_X" />
                <translation transSpeed="1" transAcceleration="10" transMin="-2.685" transMax="-1.443" translationAxis="3" startTrans="-1.443" />
            </movingTool>
            <movingTool node="handbrake" playSound="true" >
