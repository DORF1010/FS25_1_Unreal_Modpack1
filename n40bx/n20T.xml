        <hose inputAttacherJointIndices="1" type="hydraulicOut" node="hydraulicOut01" adapterNode="hydraulicOut01_connector" length="1.6" diameter="0.02" straighteningFactor="1">
            <objectChange node="hydraulicOut01_detached" visibilityActive="false" visibilityInactive="true"/>
        </hose>
        <hose inputAttacherJointIndices="1" type="electric" node="electric" adapterNode="electric_detached" length="1.6" diameter="0.01" straighteningFactor="1">
            <objectChange node="electric_detached" visibilityActive="false" visibilityInactive="true" />
        </hose>
    </connectionHoses>

    <dynamicMountAttacher triggerNode="dynamicMountTrigger" rootNode="n20T_main_component1" jointNode="dynamicMountTrigger" forceAcceleration="1000" mountType="TYPE_AUTO_ATTACH_XZ" transferMass="true">
        <lockPosition xmlFilename="vehicles/nardi/n20T/n20T.xml" jointNode="dynamicMountTriggerLock" />
    </dynamicMountAttacher>

    <foldable>
        <foldingConfigurations>
            <foldingConfiguration>
                <foldingParts startMoveDirection="0">
                    <foldingPart animationName="folding" speedScale="1.0"/>
                </foldingParts>
            </foldingConfiguration>
        </foldingConfigurations>
    </foldable>

    <animations>
        <animation name="moveSupport">
            <part node="supportArmBolt"  startTime="0.00" endTime="0.05" startTrans="-0.076 0.452 3.897" endTrans="-0.076 0.563 3.897" />
            <part node="supportArm"      startTime="0.03" endTime="0.30" startRot="60 0 0" endRot="0 0 0" tangentType="spline" />
            <part node="supportArmBolt"  startTime="0.30" endTime="0.35" startTrans="-0.076 0.563 3.897" endTrans="-0.076 0.452 3.897" />
            <part node="supportArmCrank" startTime="0.30" endTime="1.00" startRot="0 1080 0" endRot="0 0 0" />
            <part node="supportArmPart"  startTime="0.30" endTime="1.00" startTrans="-0.043 0.257 0.001" endTrans="-0.043 0.12 0.001" />
            <part node="handbrake"       startTime="0.70" endTime="1.00" startRot="0 0 0" endRot="-50 0 0" />

            <sound template="metalHandleRotate" startTime="0.3"  endTime="0.99" volumeScale="1"   pitchScale="1.5" linkNode="supportArm"/>
            <sound template="slideOpen"         startTime="0.3"  endTime="0.99" volumeScale="2"   pitchScale="2"   linkNode="supportArm"/>
            <sound template="clackVar2"         startTime="0.9"  direction="1"  volumeScale="3.0" pitchScale="1.2" linkNode="attacherJoint"/>
            <sound template="clackVar1"         startTime="0.24" direction="-1" volumeScale="3.0" pitchScale="1.4" linkNode="attacherJoint"/>
            <sound template="clackVar3"         startTime="0.2"  direction="-1" volumeScale="3.0" pitchScale="1.4" linkNode="attacherJoint"/>
        </animation>

        <animation name="folding">
            <part node="turntableMoveBolt" startTime="0.00" endTime="0.00" visibility="true"/>
            <part node="turntableMoveBolt" startTime="0.01" endTime="0.20" visibility="false"/>
            <part node="turntableLockArm"  startTime="0.05" endTime="0.15" startRot="0 0 0" endRot="0 0 50" tangentType="spline" />
            <part node="turntableLock"     startTime="0.15" endTime="0.30" startRot="0 0 0" endRot="-50 0 0" tangentType="spline" />

            <part node="turntableSplint"   startTime="0.00" endTime="0.00" visibility="true"/>
            <part node="turntableSplint"   startTime="0.01" endTime="0.20" visibility="false"/>
            <part node="turntableBolt"     startTime="0.10" endTime="0.30" startTrans="0.090 0.589 3.755" endTrans="0.090 0.541 3.755"/>
            <part node="turntableBolt"     startTime="0.70" endTime="0.90" startTrans="0.090 0.589 3.755" endTrans="0.090 0.541 3.755"/>

            <part node="turntable"         startTime="0.50" endTime="6.00" startRot="0 0 0" endRot="0 90 0" tangentType="spline" />
            <part node="turntableFlip"     startTime="6.00" endTime="8.50" startRot="0 0 0" endRot="0 0 -25" />
            <part node="turntableMove"     startTime="6.00" endTime="8.50" startTrans="0 0 0" endTrans="0.85 0 0" />

            <sound template="hydraulicClose01" startTime="0.8"  endTime="5.7"  volumeScale="3.5" pitchScale="0.5"/>
            <sound template="hydraulicOpen02"  startTime="6"    endTime="8.4"  direction="-1"    volumeScale="2.0" pitchScale="1.6"/>
            <sound template="hydraulicOpen05"  startTime="6.2"  endTime="8.4"  direction="1"     volumeScale="2.0" pitchScale="1"/>
            <sound template="clackVar1"        startTime="0.8"  direction="1"  volumeScale="3.0" pitchScale="1.4"/>
            <sound template="clackVar3"        startTime="0.8"  direction="1"  volumeScale="3.0" pitchScale="0.8"/>
            <sound template="clackVar1"        startTime="0.9"  direction="-1" volumeScale="3.0" pitchScale="1.8"/>
            <sound template="clackVar4"        startTime="0.9"  direction="-1" volumeScale="3.0" pitchScale="0.7"/>
            <sound template="clackVar3"        startTime="5.7"  direction="1"  volumeScale="4.0" pitchScale="0.8" />
            <sound template="vibratingImp"     startTime="6"    direction="1"  volumeScale="1.0" pitchScale="1"/>
            <sound template="metalImpHigh01"   startTime="6"    direction="-1" volumeScale="0.8" pitchScale="0.8"/>
            <sound template="vibratingImp"     startTime="8.35" direction="1"  volumeScale="1.0" pitchScale="1.2"/>
            <sound template="clackVar6"        startTime="8.35" direction="1"  volumeScale="3.0" pitchScale="0.7"/>
        </animation>
    </animations>

    <cylindered>
        <movingTools>
            <movingTool node="turntable">
                <dynamicMountAttacher value="true" />
            </movingTool>
            <movingTool node="turntableFlip" playSound="true" >
