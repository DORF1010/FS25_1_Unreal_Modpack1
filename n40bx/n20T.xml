        </realLights>

        <staticLightCompounds>
            <staticLightCompound>
                <node node="n20TLights_static" intensity="15"/>
                <node node="n20TLightsGlass_static" intensity="1"/>
                <node node="licensePlateLight_static" intensity="15"/>
                <node node="licensePlateLightGlass_static" intensity="1"/>
            </staticLightCompound>
        </staticLightCompounds>

        <beaconLights>
            <beaconLight node="beaconLight03" filename="$data/shared/assets/beaconLights/lizard/beaconLight03.xml" mountType="POLE" variationName="ROTATE"/>
        </beaconLights>
    </lights>

    <connectionHoses>
        <hose inputAttacherJointIndices="1" type="hydraulicIn"  node="hydraulicIn01" adapterNode="hydraulicIn01_connector" length="1.6" diameter="0.02" straighteningFactor="1">
