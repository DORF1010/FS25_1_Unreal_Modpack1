    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="attacherJoint" jointType="trailer" attacherHeight="0.575"/>
        </inputAttacherJoints>
        <support animationName="moveSupport" delayedOnAttach="false" detachAnimationTime="0.5"/>
