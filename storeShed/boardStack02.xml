<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_category_decoration</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>storeShed/store.dds</image>
        <price>1000</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>decoration</category>
        <brush>
            <type>placeable</type>
            <category>decoration</category>
            <tab>decoration</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <vertexBufferMemoryUsage>2048</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>512</indexBufferMemoryUsage>
        <textureMemoryUsage>327680</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <filename>storeShed/boardStacksTiny.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>
        <sounds>
            <place template="smallImp" pitchScale="1.6"/>
        </sounds>
    </placement>

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart filename="$data/store/ui/shop.i3d"   node="0" linkNode="0>3" />
        <dynamicallyLoadedPart filename="$data/store/ui/shop.i3d"   node="1" linkNode="0>3" />
        <!-- <dynamicallyLoadedPart filename="$data/store/ui/shop.i3d"   node="2" linkNode="0>3" /> -->
        <dynamicallyLoadedPart filename="$data/store/ui/shop.i3d"   node="3" linkNode="0>3" />
    </dynamicallyLoadedParts>

    <i3dMappings>
        <i3dMapping id="testAreaStart01" node="0>0|0" />
        <i3dMapping id="testAreaEnd01" node="0>0|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>1|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>1|0|0" />
    </i3dMappings>
</placeable>
