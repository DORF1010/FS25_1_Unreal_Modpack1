<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="implementDynamicMountAttacher" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>F155A Bale Grabber</name>
        <specs>
            <combination filterCategory="frontLoaderVehicles"/>
			<combination filterCategory="frontLoaders"/>
			<combination filterCategory="teleLoaderVehicles"/>
			<combination filterCategory="wheelLoaderVehicles"/>
			
        </specs>
        <functions>
            <function>$l10n_function_frontloaderBaleFork</function>
        </functions>
        <image>$data/vehicles/albutt/f155A/store_f155A.png</image>
        <price>500</price>
        <lifetime>6000</lifetime>
        <rotation>0</rotation>
        <brand>ALBUTT</brand>
        <category>frontLoaderTools teleLoaderTools wheelLoaderTools</category>
        <shopLoadingDelay initial="0.1"/>
        <shopTranslationOffset>0 2 0</shopTranslationOffset>
        <shopRotationOffset>-3 -180 0</shopRotationOffset>
        <vertexBufferMemoryUsage>428800</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>109824</indexBufferMemoryUsage>
        <textureMemoryUsage>393216</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_frontloaderTool</typeDesc>
        <filename>f155A/f155A.i3d</filename>
        <size width="2.85" length="2.9" height="1.05" lengthOffset="0.1"/>
        <components>
            <component centerOfMass="0 0.4 0" solverIterationCount="10" mass="450"/>
        </components>
        <schemaOverlay attacherJointPosition="0 0" name="IMPLEMENT"/>
        <mapHotspot type="TOOL"/>
    </base>

    <attachable>
        <inputAttacherJointConfigurations>
            <inputAttacherJointConfiguration name="$l10n_configuration_inputAttacherFrontLoader">
                <inputAttacherJoint node="attacherJoint_frontloader" jointType="frontloader"/>
                <objectChange node="frontloaderFrame"    visibilityActive="true" visibilityInactive="false"/>
                <objectChange node="frontloader_colPart" compoundChildActive="true"/>
                <objectChange node="telehandler_colPart" compoundChildActive="false"/>
                <objectChange node="wheelLoader_colPart" compoundChildActive="false"/>
            </inputAttacherJointConfiguration>

            <inputAttacherJointConfiguration name="$l10n_configuration_inputAttacherTeleLoaders">
                <inputAttacherJoint node="attacherJoint_telehandler" jointType="telehandler"/>
                <objectChange node="telehandlerFrame"    visibilityActive="true" visibilityInactive="false"/>
                <objectChange node="telehandler_colPart" compoundChildActive="true"/>
                <objectChange node="frontloader_colPart" compoundChildActive="false"/>
                <objectChange node="wheelLoader_colPart" compoundChildActive="false"/>
            </inputAttacherJointConfiguration>

            <inputAttacherJointConfiguration name="$l10n_configuration_inputAttacherWheelLoader">
                <inputAttacherJoint node="attacherJoint_wheelLoader" jointType="wheelLoader"/>
                <objectChange node="wheelLoaderFrame"    visibilityActive="true" visibilityInactive="false"/>
                <objectChange node="wheelLoader_colPart" compoundChildActive="true"/>
                <objectChange node="telehandler_colPart" compoundChildActive="false"/>
                <objectChange node="frontloader_colPart" compoundChildActive="false"/>
            </inputAttacherJointConfiguration>
        </inputAttacherJointConfigurations>
        <support animationName="moveSupport" />
        <brakeForce force="0.1"/>
    </attachable>

    <connectionHoses>
        <hose inputAttacherJointIndices="1" type="hydraulicIn" node="hydraulicIn01" length="1" diameter="0.0225" isTwoPointHose="true" adapterNode="hydraulicIn01_connector">
            <objectChange node="hydraulicIn01_detached" visibilityActive="false" visibilityInactive="true"/>
        </hose>
        <hose inputAttacherJointIndices="1" type="hydraulicOut" node="hydraulicOut01" length="1" diameter="0.0225" isTwoPointHose="true" adapterNode="hydraulicOut01_connector">
            <objectChange node="hydraulicOut01_detached" visibilityActive="false" visibilityInactive="true"/>
        </hose>
    </connectionHoses>

    <foldable>
        <foldingConfigurations>
            <foldingConfiguration>
                <foldingParts startMoveDirection="0" turnOnFoldDirection="1" dynamicMountMinLimit="0" dynamicMountMaxLimit="0.01" >
                    <foldingPart animationName="baleHooksAnimation" speedScale="1.0" />
                </foldingParts>
            </foldingConfiguration>
        </foldingConfigurations>
    </foldable>

    <animations>
        <animation name="baleHooksAnimation">
            <part node="hook01" startTime="0" endTime="1" startRot="0 0 0" endRot="100 0 0"/>

            <sound template="slideOpen"    startTime="0.01" endTime="0.99" volumeScale="2"   pitchScale="1.2" />
            <sound template="hingeImp"     startTime="0.1"  direction="-1" volumeScale="0.5" pitchScale="1"/>
            <sound template="vibratingImp" startTime="0.1"  direction="-1" volumeScale="0.5" pitchScale="1.5"/>
            <sound template="vibratingImp" startTime="0.99" direction="1"  volumeScale="0.7" pitchScale="1.3"/>
        </animation>

        <animation name="moveSupport">
            <part node="supportArmBoltPart" startTime="0.0" endTime="0.125" startTrans="0 0 0" endTrans="0 0.06 0" />
            <part node="supportArmBoltPart" startTime="0.125" endTime="0.126" startVisibility="true" endVisibility="false" />

            <part node="supportArmBolt" startTime="0.125" endTime="0.25" startTrans="0 0 0" endTrans="-0.055 0 0" />
            <part node="supportArmBolt" startTime="0.25" endTime="0.251" startVisibility="true" endVisibility="false" />

            <part node="supportArm" startTime="0.25" endTime="0.75" startTrans="0 0.61 -1.492" endTrans="0 0.231 -1.492" />

            <part node="supportArmBolt" startTime="0.749" endTime="0.75" startVisibility="false" endVisibility="true" />
            <part node="supportArmBolt" startTime="0.75" endTime="0.875" startTrans="-0.055 0 0" endTrans="0 0 0" />

            <part node="supportArmBoltPart" startTime="0.874" endTime="0.875" startVisibility="false" endVisibility="true" />
            <part node="supportArmBoltPart" startTime="0.875" endTime="1" startTrans="0 0.06 0" endTrans="0 0 0" />

            <sound template="slideOpen"    startTime="0.2" endTime="0.7"  direction="0"     volumeScale="1.4" pitchScale="1.5" />
            <sound template="hingeImp"     startTime="0.3" direction="-1" volumeScale="0.4" pitchScale="1.3" />
            <sound template="vibratingImp" startTime="0.3" direction="-1" volumeScale="0.7" pitchScale="1.2" />
        </animation>

        <animation name="sideBarAnimation" isKeyframe="false">
            <part node="sideBar" startTime="0" endTime="1" startTrans="-0.120 0 0" endTrans="0.360 0 0"/>

            <sound template="metalScrape"  startTime="0.01" endTime="0.99" volumeScale="0.25" pitchScale="1.5" fadeIn="0.1" fadeOut="0.1"/>
            <sound template="vibratingImp" startTime="0.01" direction="-1" volumeScale="0.7"  pitchScale="1.6" />
            <sound template="hingeImp"     startTime="0.05" direction="-1" volumeScale="0.5"  pitchScale="1.2" />
            <sound template="vibratingImp" startTime="0.99" direction="1"  volumeScale="0.5"  pitchScale="1.7" />
            <sound template="sheetImp02"   startTime="0.99" direction="1"  volumeScale="0.5"  pitchScale="0.7" />
        </animation>
    </animations>

    <tensionBeltObject>
        <meshNodes>
            <meshNode node="tensionBeltNode"/>
        </meshNodes>
    </tensionBeltObject>

    <dynamicMountAttacher triggerNode="dynamicMountTrigger" rootNode="f155A_main_component1" jointNode="f155A_main_component1" forceAcceleration="5000000000000" mountType="TYPE_AUTO_ATTACH_XYZ" timeToMount="-1" stateChangeMount="true"/>

    <cylindered>
        <cylinderedConfigurations title="$l10n_configuration_equipment">
            <cylinderedConfiguration name="$l10n_configuration_valueDefault" price="0">
                <objectChange node="sideBar"          visibilityActive="false"/>
                <objectChange node="sideBar_colPart1" compoundChildActive="false"/>
                <objectChange node="sideBar_colPart2" compoundChildActive="false"/>
            </cylinderedConfiguration>
            <cylinderedConfiguration name="$l10n_configuration_valueDesign01" price="0">
                <objectChange node="sideBarRot"       rotationActive="0 0 0" />
                <objectChange node="sideBar_colPart1" compoundChildActive="true"/>
                <objectChange node="sideBar_colPart2" compoundChildActive="true"/>
                <movingTools>
                    <movingTool node="sideBar">
                        <controls axis="AXIS_FRONTLOADER_TOOL2" invertAxis="true" mouseSpeedFactor="0.75" iconName="IMPLEMENT_TRANS_X" />
                        <animation animName="sideBarAnimation" animSpeed="1" animAcceleration="1" />
                    </movingTool>
                </movingTools>
            </cylinderedConfiguration>
            <cylinderedConfiguration name="$l10n_configuration_valueDesign02" price="0">
                <objectChange node="sideBarRot"       rotationActive="0 180 0" />
                <objectChange node="sideBar_colPart1" compoundChildActive="true"/>
                <objectChange node="sideBar_colPart2" compoundChildActive="true"/>
                <movingTools>
                    <movingTool node="sideBar">
                        <controls axis="AXIS_FRONTLOADER_TOOL2" invertAxis="true" mouseSpeedFactor="0.75" iconName="IMPLEMENT_TRANS_X" />
                        <animation animName="sideBarAnimation" animSpeed="1" animAcceleration="1" />
                    </movingTool>
                </movingTools>
            </cylinderedConfiguration>
        </cylinderedConfigurations>

        <movingTools>
            <movingTool node="hook01" playSound="true">
                <dependentPart node="hookAlignArm" />
                <dependentPart node="hook02" />
                <dependentPart node="hook03" />
                <dependentPart node="hook04" />
            </movingTool>
        </movingTools>

        <movingParts>
            <movingPart node="hookAlignArmHydraulic" referencePoint="hookAlignArmHydraulicRef" referenceFrame="hookAlignArmHydraulicRef" >
                <translatingPart node="hookAlignArmHydraulicPunch" />
            </movingPart>
            <movingPart node="hookAlignArm" referenceFrame="hook01" doRotationAlignment="true" doDirectionAlignment="false" rotMultiplier="-1" >
                <dependentPart node="hookAlignArmHydraulic" />
            </movingPart>
            <movingPart node="hook02"  referenceFrame="hook01" doRotationAlignment="true" doDirectionAlignment="false" rotMultiplier="1" />
            <movingPart node="hook03" referenceFrame="hook01" doRotationAlignment="true" doDirectionAlignment="false" rotMultiplier="1" />
            <movingPart node="hook04" referenceFrame="hook01" doRotationAlignment="true" doDirectionAlignment="false" rotMultiplier="1" />
        </movingParts>
    </cylindered>

    <ai>
        <agentAttachment width="2" height="1" length="1" lengthOffset="-0.05"/>
    </ai>

    <foliageBending>
        <bendingNode minX="-0.95" maxX="0.95" minZ="-0.5" maxZ="-0.1" yOffset="0.05" />
    </foliageBending>

    <wearable wearDuration="480" workMultiplier="5" fieldMultiplier="2"/>
    <washable dirtDuration="90"  workMultiplier="3" fieldMultiplier="2" washDuration="1"/>

    <i3dMappings>
        <i3dMapping id="f155A_main_component1" node="0>" />
        <i3dMapping id="frontloaderFrame" node="0>0|0|0|0" />
        <i3dMapping id="attacherJoint_frontloader" node="0>0|0|0|0|0" />
        <i3dMapping id="frontloader_colPart" node="0>0|0|0|0|1" />
        <i3dMapping id="telehandlerFrame" node="0>0|0|0|1" />
        <i3dMapping id="attacherJoint_telehandler" node="0>0|0|0|1|0" />
        <i3dMapping id="telehandler_colPart" node="0>0|0|0|1|1" />
        <i3dMapping id="wheelLoaderFrame" node="0>0|0|0|2" />
        <i3dMapping id="attacherJoint_wheelLoader" node="0>0|0|0|2|0" />
        <i3dMapping id="wheelLoader_colPart" node="0>0|0|0|2|1" />
        <i3dMapping id="supportArm" node="0>0|0|1|0" />
        <i3dMapping id="supportArmBolt" node="0>0|0|1|1|0" />
        <i3dMapping id="supportArmBoltPart" node="0>0|0|1|2|0" />
        <i3dMapping id="hydraulicIn01" node="0>0|0|2|0" />
        <i3dMapping id="hydraulicIn01_detached" node="0>0|0|2|0|0" />
        <i3dMapping id="hydraulicIn01_connector" node="0>0|0|2|0|0|0" />
        <i3dMapping id="hydraulicOut01" node="0>0|0|2|1" />
        <i3dMapping id="hydraulicOut01_detached" node="0>0|0|2|1|0" />
        <i3dMapping id="hydraulicOut01_connector" node="0>0|0|2|1|0|0" />
        <i3dMapping id="hook01" node="0>0|1|0" />
        <i3dMapping id="hookAlignArm" node="0>0|1|0|0" />
        <i3dMapping id="hookAlignArmHydraulicRef" node="0>0|1|0|0|0" />
        <i3dMapping id="hook02" node="0>0|1|1" />
        <i3dMapping id="hook03" node="0>0|1|2" />
        <i3dMapping id="hook04" node="0>0|1|3" />
        <i3dMapping id="hookAlignArmHydraulic" node="0>0|1|4" />
        <i3dMapping id="hookAlignArmHydraulicPunch" node="0>0|1|4|0" />
        <i3dMapping id="sideBarRot" node="0>0|2|0" />
        <i3dMapping id="sideBar" node="0>0|2|0|0" />
        <i3dMapping id="sideBar_colPart1" node="0>0|2|0|0|0" />
        <i3dMapping id="sideBar_colPart2" node="0>0|2|0|0|1" />
        <i3dMapping id="dynamicMountTrigger" node="0>0|4" />
        <i3dMapping id="tensionBeltNode" node="0>3" />
    </i3dMappings>
</vehicle>
