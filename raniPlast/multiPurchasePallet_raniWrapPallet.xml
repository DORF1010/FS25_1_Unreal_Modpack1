<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="multipleItemPurchase" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>RaniWrap Custom</name>
        <specs>
            <fillTypes>BALE_WRAP</fillTypes>
            <weight ignore="true"/>
        </specs>
        <functions>
            <function>$l10n_function_baleWrap</function>
        </functions>
        <image>raniPlast/store_raniWrapPallet.png</image>
        <price>1000</price>
        <allowLeasing>false</allowLeasing>
        <canBeSold>true</canBeSold>
        <rotation>0</rotation>
        <brand>RANIPLAST</brand>
        <category>pallets palletBaling</category>
        <financeCategory>OTHER</financeCategory>
        <shopHeight>1.5</shopHeight>
        <vertexBufferMemoryUsage>512</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>256</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>

        <storeIconRendering>
            <settings cameraXRot="-15" cameraYRot="35" />
        </storeIconRendering>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>$data/objects/multiPurchaseItem/multiPurchaseItem.i3d</filename>
        <size width="2.8" length="4.4" height="1.7" lengthOffset="0.0"/>
        <input allowed="true"/>
        <canBeReset>true</canBeReset>
        <components>
            <component centerOfMass="0 0.1 0" solverIterationCount="10" mass="99" />
        </components>
        <showInVehicleMenu>true</showInVehicleMenu>
        <mapHotspot available="true" />
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration name="$l10n_configuration_valueDefault">
                <fillUnits>
                    <fillUnit unitTextOverride="$l10n_unit_rolls" fillTypes="BALE_WRAP" capacity="40" />
                </fillUnits>
            </fillUnitConfiguration>
            <fillUnitConfiguration name="$l10n_configuration_unreal1">
                <fillUnits>
                    <fillUnit unitTextOverride="$l10n_unit_rolls" fillTypes="BALE_WRAP" capacity="400" />
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <consumable>
        <consumableConfigurations title="$l10n_configuration_baleWrap" typeName="BALE_WRAP">
            <consumableConfiguration name="$l10n_configuration_specialEdition"       consumableName="DORF_BALEWRAP"/>
            <consumableConfiguration name="%s %s" params="$l10n_consumable_raniPlastBlack|$l10n_configuration_specialEdition"       consumableName="DORF_BALEWRAP_BLACK"/>
            <consumableConfiguration name="%s %s" params="$l10n_consumable_raniPlastWhite|$l10n_configuration_specialEdition"       consumableName="DORF_BALEWRAP_WHITE"/>
            <consumableConfiguration name="FENDT"       consumableName="DORF_BALEWRAP_FENDT"/>
            <consumableConfiguration name="Neon Green"       consumableName="DORF_BALEWRAP_NEONGREEN"/>
            <consumableConfiguration name="Green"       consumableName="DORF_BALEWRAP_GREEN"/>
            <consumableConfiguration name="Harvest Moon Blue"       consumableName="DORF_BALEWRAP_BLUE"/>
            <consumableConfiguration name="$l10n_configuration_valueCamouflage"       consumableName="DORF_BALEWRAP_CAMO"/>
        </consumableConfigurations>
    </consumable>

    <baseColorConfigurations useDefaultColors="true">
        <material materialSlotName="wrapRoll_mat" useColorOnly="true" ignoreWarning="true"/>
        <baseColorConfiguration materialTemplateName="SHARED_WRAP_WHITE"/>
        <baseColorConfiguration materialTemplateName="SHARED_WRAP_BLACK"/>
        <baseColorConfiguration materialTemplateName="SHARED_WRAP_BLUE"/>
        <baseColorConfiguration materialTemplateName="SHARED_WRAP_GREEN"/>
        <baseColorConfiguration materialTemplateName="SHARED_WRAP_PINK"/>
        <baseColorConfiguration materialTemplateName="CASEIH_GREY" name="$l10n_ui_colorSilver"/>
        <baseColorConfiguration materialTemplateName="RIM_CONFIGURATION_CHROME"/>
    </baseColorConfigurations>

    <multipleItemPurchase filename="raniPlast/raniWrapPallet.xml" isVehicle="true">
        <offsets>
            <offset amount="2" offset="0.7 0 0"/>
            <offset amount="3" offset="0.7 0 0.55"/>
            <offset amount="5" offset="0.7 0 1.1"/>
            <offset amount="7" offset="0.7 0 1.65"/>
        </offsets>
        <itemPositions>
            <itemPosition position="0 0 0" rotation="0 0 0"/>
            <itemPosition position="-1.4 0 0" rotation="0 0 0"/>
            <itemPosition position="0 0 -1.1" rotation="0 0 0"/>
            <itemPosition position="-1.4 0 -1.1" rotation="0 0 0"/>

            <itemPosition position="0 0 -2.2" rotation="0 0 0"/>
            <itemPosition position="-1.4 0 -2.2" rotation="0 0 0"/>
            <itemPosition position="0 0 -3.3" rotation="0 0 0"/>
            <itemPosition position="-1.4 0 -3.3" rotation="0 0 0"/>
			
			<!--second layer-->
            <itemPosition position="0 1 0" rotation="0 0 0"/>
            <itemPosition position="-1.4 1 0" rotation="0 0 0"/>
            <itemPosition position="0 1 -1.1" rotation="0 0 0"/>
            <itemPosition position="-1.4 1 -1.1" rotation="0 0 0"/>

            <itemPosition position="0 1 -2.2" rotation="0 0 0"/>
            <itemPosition position="-1.4 1 -2.2" rotation="0 0 0"/>
            <itemPosition position="0 1 -3.3" rotation="0 0 0"/>
            <itemPosition position="-1.4 1 -3.3" rotation="0 0 0"/>
        </itemPositions>
    </multipleItemPurchase>

    <multipleItemPurchaseAmountConfigurations>
        <multipleItemPurchaseAmountConfiguration name="1"  price="0"/>
        <multipleItemPurchaseAmountConfiguration name="2"  price="1000"/>
        <multipleItemPurchaseAmountConfiguration name="3"  price="2000"/>
        <multipleItemPurchaseAmountConfiguration name="4"  price="3000"/>
        <multipleItemPurchaseAmountConfiguration name="5"  price="4000"/>
        <multipleItemPurchaseAmountConfiguration name="6"  price="5000"/>
        <multipleItemPurchaseAmountConfiguration name="7"  price="6000"/>
        <multipleItemPurchaseAmountConfiguration name="8"  price="7000"/>
        <multipleItemPurchaseAmountConfiguration name="9"  price="8000"/>
        <multipleItemPurchaseAmountConfiguration name="10" price="9000"/>
        <multipleItemPurchaseAmountConfiguration name="11" price="10000"/>
        <multipleItemPurchaseAmountConfiguration name="12" price="11000"/>
        <multipleItemPurchaseAmountConfiguration name="13" price="12000"/>
        <multipleItemPurchaseAmountConfiguration name="14" price="13000"/>
        <multipleItemPurchaseAmountConfiguration name="15" price="14000"/>
        <multipleItemPurchaseAmountConfiguration name="16" price="15000"/>
    </multipleItemPurchaseAmountConfigurations>

</vehicle>