<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="mower" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>Implement Extension Arm</name>
        <specs>
            <combination filterCategory="weights" filterSpec="weight" filterSpecMin="600" filterSpecMax="1500"/>
        </specs>
        <functions>
            <function>$l10n_function_dolly</function>
        </functions>
        <image>implementArm/store_arm.dds</image>
        <price>10000</price>
        <lifetime>600</lifetime>
        <rotation>0</rotation>
        <brand>DORF</brand>
        <category>misc</category>
        <shopTranslationOffset>0 0 0</shopTranslationOffset>
        <shopRotationOffset>0 0 0</shopRotationOffset>
        <vertexBufferMemoryUsage>849664</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>231168</indexBufferMemoryUsage>
        <textureMemoryUsage>458752</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_tool</typeDesc>
        <filename>implementArm/arm.i3d</filename>
        <size width="3" length="1.65" height="4.25" lengthOffset="-0.08" widthOffset="-0.2"/>
        <components>
            <component centerOfMass="0 0 0" solverIterationCount="10" mass="930"/>
        </components>
        <schemaOverlay attacherJointPosition="0 0" name="IMPLEMENT"/>
        <mapHotspot type="TOOL"/>
    </base>

    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="0>0" jointType="implement" upperRotationOffset="0" lowerTransLimitScale="0 0 0" lowerRotLimitScale="0 0 0" allowsLowering="false">
                <distanceToGround lower="0.8" upper="00.8"/>
                <bottomArm categories="2 3" ballType="1"/>
            </inputAttacherJoint>
        </inputAttacherJoints>
    </attachable>

    <attacherJoints>
        <attacherJoint node="0>1" jointType="implement" lowerRotLimit="0 0 0" enableCollision="false" >
            <schema position="1 0" rotation="0" invertX="false" />
        </attacherJoint>
		<attacherJoint node="0>2|0|0|0|0" jointType="implement" lowerRotLimit="0 0 0" enableCollision="false" >
			<schema position="1 1" rotation="0" invertX="false" />
		</attacherJoint>
		<attacherJoint node="0>2|0|0|0|1" jointType="implement" lowerRotLimit="0 0 0" enableCollision="false" >
			<schema position="0 0" rotation="0" invertX="true" />
		</attacherJoint>
        <sounds>
            <attach template="attach01" linkNode="0>" />
        </sounds>
    </attacherJoints>

    <foldable>
        <foldingConfigurations>
            <foldingConfiguration>
                <foldingParts startAnimTime="1" foldMiddleAnimTime="0.2" turnOnFoldMaxLimit="0.2" detachingMinLimit="1" unfoldWarning="$l10n_warning_firstFoldUpTheTool">
                    <foldingPart animationName="folding" speedScale="1"/>
                </foldingParts>
            </foldingConfiguration>
        </foldingConfigurations>
    </foldable>

    <animations>
        <animation name="folding">
            <part node="0>2|0" startTime="0" endTime="5" startRot="0 0 0" endRot="0 0 131"/>
        </animation>
    </animations>
