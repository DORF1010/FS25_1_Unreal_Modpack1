        <baseColorConfiguration color="FENDT_OLDGREEN1" />
        <baseColorConfiguration color="FENDT_BLUE1"/>
        <baseColorConfiguration color="FENDT_ORANGE1"/>
        <baseColorConfiguration materialTemplateName="RIM_CONFIGURATION_CHROME"/>
    </baseColorConfigurations>

