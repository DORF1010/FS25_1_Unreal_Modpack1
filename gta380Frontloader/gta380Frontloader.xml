<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="attachableFrontloader" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name params="$l10n_typeDesc_frontloader">GTA %s</name>
        <specs>
            <combination xmlFilename="gta380/gta380.xml"/>
            <combination filterCategory="frontLoaderTools"/>
        </specs>
        <functions>
            <function>$l10n_function_frontloader</function>
        </functions>
        <image>gta380Frontloader/store_gta380Frontloader.png</image>
        <price>4000</price>
        <lifetime>600</lifetime>
        <rotation>0</rotation>
        <brand>FENDT</brand>
        <category>frontLoaders</category>
        <shopHeight>2.25</shopHeight>
        <shopLoadingDelay config="0.2"/>
        <shopTranslationOffset>0 0.27 0</shopTranslationOffset>
        <shopRotationOffset>25.008 0 0</shopRotationOffset>
        <vertexBufferMemoryUsage>513280</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>145664</indexBufferMemoryUsage>
        <textureMemoryUsage>1114112</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_frontloader</typeDesc>
        <filename>gta380Frontloader/gta380Frontloader.i3d</filename>
        <size width="1.3" length="2.35" height="2.25" lengthOffset="1.02"/>
        <components>
            <component centerOfMass="0 0.2 1.3" solverIterationCount="10" mass="485"/>
        </components>
        <schemaOverlay attacherJointPosition="0 0" name="FRONTLOADER"/>
        <mapHotspot type="TOOL"/>
    </base>

    <configurationSets isYesNoOption="true">
        <configurationSet name="$l10n_configuration_valueNo">
            <configuration name="design"          index="1"/>
            <configuration name="handToolHolder"     index="2"/>
        </configurationSet>
        <configurationSet name="$l10n_configuration_valueYes">
            <configuration name="design"     index="2"/>
            <configuration name="handToolHolder"     index="1"/>
        </configurationSet>
    </configurationSets>

    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="attacherJoint" hardAttach="true" jointType="attachableFrontloader"/>
        </inputAttacherJoints>
        <support animationName="moveSupport"/>
    </attachable>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn01_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn02_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn03_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn04_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn05_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn06_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn07_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
        <dynamicallyLoadedPart node="1|0" linkNode="hydraulicIn08_detachedAdapter" filename="$data/shared/connectionHoses/connectors.i3d"/>
    </dynamicallyLoadedParts>

    <attacherJoints>
        <attacherJoint jointType="frontloader" node="attacherJointTools" nodeVisual="attacherJointToolsVisuals" allowsJointLimitMovement="false" allowsLowering="false" rotLimitSpring="7500 7500 7500" rotLimitDamping="5 5 5" transLimitSpring="7500 7500 7500" transLimitDamping="5 5 5">
            <schema position="1 0" rotation="0" invertX="false"/>
            <objectChange node="lockLeft" translationActive="0 0 0" translationInactive="-0.11 0 0"/>
            <objectChange node="lockRight" translationActive="0 0 0" translationInactive="0.11 0 0"/>
            <objectChange node="lockIndicator" translationActive="0 0 0" translationInactive="0 0 0.015"/>
        </attacherJoint>
        <sounds>
            <attach template="attach01" linkNode="frontloader_main_component1"/>
        </sounds>
    </attacherJoints>

    <connectionHoses>
        <hose inputAttacherJointIndices="1" type="hydraulicIn" node="hydraulicIn01" length="0.75" diameter="0.012" dampingFactor="0" straighteningFactor="0.2">
            <objectChange node="detachedHoses" visibilityActive="false" visibilityInactive="true"/>
            <objectChange node="attachedHoses" visibilityActive="true" visibilityInactive="false"/>
            <objectChange node="localHosesAttached" visibilityActive="true" visibilityInactive="false"/>
        </hose>
        <hose inputAttacherJointIndices="1" type="hydraulicIn" node="hydraulicIn02" length="0.75" diameter="0.012" dampingFactor="0" straighteningFactor="0.2"/>
        <hose inputAttacherJointIndices="1" type="hydraulicIn" node="hydraulicIn03" length="0.75" diameter="0.012" dampingFactor="0" straighteningFactor="0.2"/>
        <hose inputAttacherJointIndices="1" type="hydraulicIn" node="hydraulicIn04" length="0.75" diameter="0.012" dampingFactor="0" straighteningFactor="0.2"/>

        <localHose>
            <hose type="hydraulicIn" node="hoseHydraulicIn01" isWorldSpaceHose="false" isTwoPointHose="true" length="1.0" adapterType="NONE" dampingFactor="0" straighteningFactor="2.5" diameter="0.012"/>
            <target type="hydraulicIn" node="targetHydraulicIn01"/>
        </localHose>
        <localHose>
            <hose type="hydraulicIn" node="hoseHydraulicIn02" isWorldSpaceHose="false" isTwoPointHose="true" length="1.0" adapterType="NONE" dampingFactor="0" straighteningFactor="2.5" diameter="0.012"/>
            <target type="hydraulicIn" node="targetHydraulicIn02"/>
        </localHose>
        <localHose>
            <hose type="hydraulicIn" node="hoseHydraulicIn03" isWorldSpaceHose="false" isTwoPointHose="true" length="1.0" adapterType="NONE" dampingFactor="0" straighteningFactor="2.5" diameter="0.012"/>
            <target type="hydraulicIn" node="targetHydraulicIn03"/>
        </localHose>
        <localHose>
            <hose type="hydraulicIn" node="hoseHydraulicIn04" isWorldSpaceHose="false" isTwoPointHose="true" length="1.0" adapterType="NONE" dampingFactor="0" straighteningFactor="2.5" diameter="0.012"/>
            <target type="hydraulicIn" node="targetHydraulicIn04"/>
        </localHose>
    </connectionHoses>

    <animations>
        <animation name="moveSupport">
            <part node="supportcol" startTime="0" endTime="0.1" startTrans="0 3.4 1.752" endTrans="0 0 0"/>
            <part node="supportcol" startTime="0.1" endTime="0.2" startRot="121.573 0 0" endRot="0 0 0"/>
            <part node="supportArms" startTime="0" endTime="0.1" visibility="false"/>
            <part node="supportArms" startTime="0.1" endTime="0.2" visibility="true"/>
            <part node="attachFrame" startTime="0" endTime="0.1" visibility="true"/>
            <part node="attachFrame" startTime="0.1" endTime="0.2" visibility="false"/>
        </animation>
    </animations>

    <cylindered>
        <movingTools>
            <movingTool node="armDummy" delayedNode="arm">
                <controls axis="AXIS_FRONTLOADER_ARM" invertAxis="true" mouseSpeedFactor="0.45" iconName="FRONTLOADER_ARM_ROTATE"/>
                <attacherJoint jointIndices="1"/>
                <rotation rotSpeed="20" rotAcceleration="150" rotMax="13" rotMin="-60" startRot="1" detachingRotMinLimit="-10" detachingRotMaxLimit="20"/>
                <dependentPart node="attacherRotDummy"/>
                <dependentMovingTool node="attacherDummy" minRotLimits="-25 -22" maxRotLimits="80 90"/>
            </movingTool>
            <movingTool node="attacherDummy" delayedNode="attacher">
                <controls axis="AXIS_FRONTLOADER_TOOL" invertAxis="true" mouseSpeedFactor="0.45" iconName="FRONTLOADER_ARM_ROTATE_TOOL"/>
                <attacherJoint jointIndices="1"/>
                <rotation rotSpeed="50" rotAcceleration="300" rotMax="85" rotMin="-25" startRot="-16" syncMaxRotLimits="true"/>
            </movingTool>
            <movingTool node="arm">
                <dependentPart node="hydraulicMain"/>
                <dependentPart node="attacherRot"/>
                <dependentPart node="wingArmPart"/>
            </movingTool>
            <movingTool node="attacher">
                <dependentPart node="wingArmPart"/>
            </movingTool>
        </movingTools>

        <movingParts>
            <movingPart node="attacherRotDummy" referenceFrame="frontloader_main_component1">
                <attacherJoint jointIndices="1"/>
            </movingPart>
            <movingPart node="attacherRot" referenceFrame="frontloader_main_component1">
                <attacherJoint jointIndices="1"/>
                <dependentPart node="armPart01"/>
            </movingPart>
             <movingPart node="hydraulicMain" referencePoint="hydraulicMainRef" referenceFrame="hydraulicMainRef">
                <translatingPart node="hydraulicMainPunch"/>
            </movingPart>
            <movingPart node="wingArmPart" localReferencePoint="wingArm" referencePoint="wingArmRef" referenceFrame="wingArmPartRefFrame">
                <dependentPart node="wingArm"/>
                <dependentPart node="hydraulicFront"/>
                <dependentPart node="armPart01"/>
            </movingPart>
            <movingPart node="wingArm" referencePoint="wingArmRef" referenceFrame="wingArmRefFrame"/>
            <movingPart node="armPart01" localReferencePoint="armPart02" referencePoint="armPart02Ref" referenceFrame="armPart01RefFrame">
                <dependentPart node="armPart02"/>
                <dependentPart node="hydraulicFront"/>
            </movingPart>
            <movingPart node="armPart02" referencePoint="armPart02Ref" referenceFrame="armPart02Ref"/>
            <movingPart node="hydraulicFront" referencePoint="hydraulicFrontRef" referenceFrame="hydraulicFrontRefFrame">
                <translatingPart node="hydraulicFrontPunch"/>
            </movingPart>
        </movingParts>

        <sounds>
            <actionSound template="hydraulicOpen01"     pitchScale="1.5" volumeScale="2.6" linkNode="hydraulicMain"   actionNames="TRANSLATING_POS " nodes="hydraulicMain" fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicSoftOpen01" pitchScale="1.2" volumeScale="1.6" linkNode="hydraulicMain"   actionNames="TRANSLATING_NEG" nodes="hydraulicMain" fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicSmallOpen"  pitchScale="1.8" volumeScale="1.0" linkNode="hydraulicFront" actionNames="TRANSLATING_POS " nodes="hydraulicFront" fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="hydraulicSmallClose" pitchScale="1.1" volumeScale="1.8" linkNode="hydraulicFront" actionNames="TRANSLATING_POS TRANSLATING_NEG" nodes="hydraulicFront" fadeIn="0.1" fadeOut="0.05"/>
            <actionSound template="metalLowVar2"  pitchScale="1.0" volumeScale="4"   linkNode="armDummy"   actionNames="TOOL_MOVE_END_POS_LIMIT" nodes="armDummy"/>
            <actionSound template="cylinderPunch" pitchScale="1.5" volumeScale="0.7" linkNode="armDummy"   actionNames="TOOL_MOVE_END_POS_LIMIT" nodes="armDummy"/>
            <actionSound template="metalClose"    pitchScale="2.5" volumeScale="0.4" linkNode="armDummy"   actionNames="TOOL_MOVE_END_POS_LIMIT" nodes="armDummy"/>
            <actionSound template="clackVar6"     pitchScale="1.0" volumeScale="1.5" linkNode="armDummy"   actionNames="TOOL_MOVE_END_POS_LIMIT" nodes="armDummy"/>

            <actionSound template="metalLowVar2"  pitchScale="1.3" volumeScale="2.5"   linkNode="armDummy" actionNames="TOOL_MOVE_END_NEG_LIMIT" nodes="armDummy"/>
            <actionSound template="cylinderPunch" pitchScale="1.8" volumeScale="0.4" linkNode="armDummy"   actionNames="TOOL_MOVE_END_NEG_LIMIT" nodes="armDummy"/>
            <actionSound template="metalClose"    pitchScale="2.8" volumeScale="0.3" linkNode="armDummy"   actionNames="TOOL_MOVE_END_NEG_LIMIT" nodes="armDummy"/>
            <actionSound template="clackVar6"     pitchScale="1.8" volumeScale="0.7" linkNode="armDummy"   actionNames="TOOL_MOVE_END_NEG_LIMIT" nodes="armDummy"/>
        </sounds>
    </cylindered>

    <handToolHolders>
        <handToolHolderConfigurations>
            <handToolHolderConfiguration>
                <handToolHolder>
                    <holder type="CHAINSAW" node="chainsawHolderNode" dummyFilename="$data/shared/visualization/dummyChainsaw.i3d" />
                    <trigger node="playerTrigger" />
                </handToolHolder>
            </handToolHolderConfiguration>
            <handToolHolderConfiguration />
        </handToolHolderConfigurations>
    </handToolHolders>

    <designConfigurations>
        <designConfiguration>
            <objectChange node="woodFrame" visibilityActive="false"/>
            <objectChange node="detachedHoses02" visibilityActive="true" visibilityInactive="false"/>
        </designConfiguration>
        <designConfiguration>
            <objectChange node="woodFrame" visibilityActive="true"/>
            <objectChange node="detachedHoses01" visibilityActive="true" visibilityInactive="false"/>
        </designConfiguration>
    </designConfigurations>

    <wearable wearDuration="480" workMultiplier="5" fieldMultiplier="2"/>
    <washable dirtDuration="90" washDuration="1" workMultiplier="3" fieldMultiplier="2"/>

    <ai>
        <agentAttachment width="1.15" height="2.15" length="2.6" lengthOffset="0.62"/>
    </ai>

    <foliageBending>
        <bendingNode minX="-0.6" maxX="0.6" minZ="-0.2" maxZ="0.2" yOffset="-0.05" node="attacherRot"/>
    </foliageBending>

    <baseColorConfigurations price="0" useDefaultColors="true" title="$l10n_configuration_chassisColor">
