            <movingPart node="safetyArm02" referencePoint="pullRopeAlignmentNode" referenceFrame="safetyArm02RefFrame" limitedAxis="2" isActiveDirty="true" maxUpdateDistance="1000" scaleZ="true"/>
        </movingParts>
    </cylindered>

