                <hookNode node="additionalHook02XRot" alignXRot="true" minRot="-30" maxRot="30"/>
                <hookNode node="additionalHook02EndPart" alignToTarget="true"/>
            </additionalRope>
            <additionalRope referenceNode="additionalHook03EndPartRef">
                <rope filename="$data/shared/forestry/ropes.i3d" ropeNode="4" diameter="0.015" uvScale="4"/>

                <hookNode node="additionalHook03YRot" alignYRot="true"/>
                <hookNode node="additionalHook03XRot" alignXRot="true" minRot="-30" maxRot="30"/>
                <hookNode node="additionalHook03EndPart" alignToTarget="true"/>
            </additionalRope>
        </additionalRopes>

        <treeHook filename="$data/shared/forestry/treeHook01.xml"/>

        <sounds>
            <detachTree file="$data/vehicles/koller/k300/sounds/detachTree.wav" pitchScale="1" innerRadius="3" outerRadius="20" supportsReverb="false">
