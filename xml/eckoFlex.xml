                <additionalRope filename="$data/shared/forestry/ropes.i3d" ropeNode="4" diameter="0.015" uvScale="4" emissiveColor="0 2 0 1"/>
                <marker filename="$data/shared/forestry/targetTreeMarker.i3d" width="0.1" offset="0.005" color="0 2 0"/>
            </attach>
            <objectChange node="ropeOrigin" visibilityActive="true" visibilityInactive="false"/>
            <objectChange node="hookRootNode_detached" visibilityActive="false" visibilityInactive="true"/>
        </rope>

        <additionalRopes>
            <additionalRope referenceNode="additionalHook01EndPartRef">
                <rope filename="$data/shared/forestry/ropes.i3d" ropeNode="4" diameter="0.015" uvScale="4"/>

                <hookNode node="additionalHook01YRot" alignYRot="true"/>
                <hookNode node="additionalHook01XRot" alignXRot="true" minRot="-30" maxRot="30"/>
