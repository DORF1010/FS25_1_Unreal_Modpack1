            <lift file="$data/vehicles/koller/k300/sounds/carriageLoopLower.wav" volumeScale="1" pitchScale="0.8" innerRadius="3" outerRadius="20" supportsReverb="false" fadeIn="0.1" fadeOut="0.1">
                <volume indoor="0.4" outdoor="1"/>
