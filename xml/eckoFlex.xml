            <liftLimit file="$data/vehicles/koller/k300/sounds/carriageLimit01.wav" pitchScale="1" innerRadius="5" outerRadius="25" supportsReverb="false" fadeIn="0.1" fadeOut="0.1">
                <volume indoor="0.7" outdoor="3"/>
            </liftLimit>
        </sounds>
